# ============================================================
# PRODUCTION CONFIG — Falaya SFA
# Salin ke .env dan isi semua nilai sebelum go-live
# ============================================================

APP_NAME="Falaya SFA"
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=stack
LOG_LEVEL=warning                 # bukan debug — hindari log sensitif

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres_db
DB_PORT=5432
DB_DATABASE=falaya_db
DB_USERNAME=falaya_user
DB_PASSWORD=                      # isi password kuat

# Redis (queue only)
REDIS_CLIENT=phpredis
REDIS_HOST=redis_cache
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=2
REDIS_CACHE_DB=2

# Session & Cache (database, bukan Redis)
SESSION_DRIVER=database
SESSION_LIFETIME=480              # 8 jam -- salesman kerja seharian
CACHE_STORE=database

# Queue
QUEUE_CONNECTION=redis

# Cloudflare R2 (foto kunjungan, PDF invoice/receipt)
FILESYSTEM_DISK=r2
AWS_ACCESS_KEY_ID=                # R2 Access Key ID
AWS_SECRET_ACCESS_KEY=            # R2 Secret Access Key
AWS_DEFAULT_REGION=auto
AWS_BUCKET=                       # nama bucket R2
AWS_URL=                          # https://<account>.r2.cloudflarestorage.com
AWS_ENDPOINT=                     # https://<account>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# Mail (opsional di MVP)
MAIL_MAILER=log

# Feature flags
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
